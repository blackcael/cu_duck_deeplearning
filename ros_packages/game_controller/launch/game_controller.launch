<launch>
  <node pkg="game_controller"
        type="controller.py"
        name="gamepad_to_joy"
        output="screen">
    <param name="rate_hz" value="20" />
    <param name="preferred_name" value="8BitDo" />
    <rosparam param="axis_map">[0, 1, 2, 3]</rosparam>
    <param name="invert_y" value="true" />
    <param name="deadzone" value="0.08" />
  </node>
</launch>
